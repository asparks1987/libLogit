{
  "name": "basic_text_file",
  "description": "A text LOGIT writes console/file style output without timestamps.",
  "clock": {
    "fixed_at": "2026-01-02T03:04:05Z"
  },
  "config": {
    "version": "0.2",
    "defaults": {
      "level": "debug",
      "timestamp": false,
      "tag_level": true,
      "format": "text",
      "sinks": ["file"]
    },
    "logits": {
      "AppLog": {
        "path": "app.log"
      }
    }
  },
  "messages": [
    {
      "logger": "AppLog",
      "level": "debug",
      "fragments": ["alpha", " ", "one"]
    },
    {
      "logger": "AppLog",
      "level": "info",
      "fragments": ["beta two"]
    }
  ],
  "expected_files": {
    "app.log": ["DEBUG alpha one", "INFO beta two"]
  }
}
